# Required: your OpenRouter API key (get one at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-your-key-here

# Max tokens per generation call
MAX_TOKENS=16000

# Repair attempts after browser tests fail (0 = no repair)
MAX_RETRIES=1

# Per-call timeout in milliseconds (8 minutes default)
OPENROUTER_TIMEOUT_MS=480000

# Output mode for generated pages
ARTIFACT_OUTPUT_MODE=html

# Reasoning effort: "none" saves tokens, "default" omits the parameter
OPENROUTER_REASONING_EFFORT=none

# Set to 0 to include reasoning text in API responses
# OPENROUTER_REASONING_EXCLUDE=0

# Manual USD/CNY rate override. If omitted, the runner fetches the latest rate.
# USD_CNY=6.8336

# Custom OpenRouter-compatible endpoint (for self-hosted proxies)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# API key header for private proxy (X-Proxy-API-Key)
# OPENROUTER_PROXY_API_KEY=

# Set to 0 if a provider rejects response_format json_object
# OPENROUTER_JSON_MODE=0
